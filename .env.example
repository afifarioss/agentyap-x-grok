# Privy Authentication (Base L2 embedded wallet)
NEXT_PUBLIC_PRIVY_APP_ID=pk_live_your_privy_app_id

# OpenRouter API (Free AI generation — no payment card needed)
# Get free key at: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key

# Neynar API (Farcaster signer & casting)
NEYNAR_API_KEY=your_neynar_api_key
NEYNAR_CLIENT_ID=your_neynar_client_id
NEXT_PUBLIC_FARCASTER_CLIENT_ID=your_neynar_client_id

# Vercel Cron Secret (optional, for heartbeat endpoint security)
CRON_SECRET=your_secure_random_cron_secret
