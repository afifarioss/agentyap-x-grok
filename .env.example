# Privy Authentication (Base L2 embedded wallet)
NEXT_PUBLIC_PRIVY_APP_ID=pk_live_your_privy_app_id

# xAI Grok API
GROK_API_KEY=xai_your_grok_api_key
XAI_API_KEY=xai_your_xai_api_key  # Fallback option

# Neynar API (Farcaster signer & casting)
NEYNAR_API_KEY=your_neynar_api_key

# Vercel Cron Secret (for heartbeat endpoint security)
CRON_SECRET=your_secure_random_cron_secret

# Grok Model (optional, defaults to grok-4.3)
# GROK_MODEL=grok-4.3
