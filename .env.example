# ─── Authentication ─────────────────────────────────────────
# Privy (Base L2 embedded wallet)
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id

# Farcaster Developer Account (for signer & heartbeat agent)
FARCASTER_DEVELOPER_FID=your_farcaster_fid_number
FARCASTER_DEVELOPER_MNEMONIC=word1 word2 ... word12

# ─── AI / LLM APIs ──────────────────────────────────────────
# OpenAI (GPT-4o-mini for cast generation)
OPENAI_API_KEY=sk-your_openai_api_key

# OpenRouter (Llama 4 Maverick — used as fallback/alternative)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key

# ─── Farcaster / Neynar ─────────────────────────────────────
# Neynar API (signer creation & casting)
NEYNAR_API_KEY=your_neynar_api_key
NEYNAR_CLIENT_ID=your_neynar_client_id

# ─── Database / KV ──────────────────────────────────────────
# Upstash Redis (for caching, rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# Vercel KV (alternative to Upstash)
KV_URL=redis://your-kv-url
KV_REST_API_URL=https://your-kv-url
KV_REST_API_TOKEN=your_kv_token
KV_REST_API_READ_ONLY_TOKEN=your_kv_readonly_token

# ─── Security ───────────────────────────────────────────────
# Vercel Cron Secret (heartbeat endpoint)
# Generate: openssl rand -hex 32
CRON_SECRET=your_32_char_hex_secret

# ─── Optional: Encryption ───────────────────────────────────
# Used to encrypt hub signing keys before sending to client
# Any 32+ character string you make up
ENCRYPTION_KEY=your-32-char-encryption-key-here!!
